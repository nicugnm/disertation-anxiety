*.parquet filter=lfs diff=lfs merge=lfs -text
# Per-experiment train/val/test splits were committed as regular blobs before LFS;
# keep them out of LFS so they don't show as perpetually "modified".
experiments/runs/*/train.parquet -filter -diff -merge
experiments/runs/*/test.parquet -filter -diff -merge
experiments/runs/*/val.parquet -filter -diff -merge

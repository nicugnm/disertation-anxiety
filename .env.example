# Copy to .env and fill in. .env is git-ignored.

# --- Reddit API (PRAW) ---
# Create an app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=anxiety-research/0.1 (by u/your_username)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- Anthropic API (Tier-2 labeling, zero-shot baseline) ---
ANTHROPIC_API_KEY=

# --- Optional: HuggingFace (for gated models like MentalBERT mirrors) ---
HF_TOKEN=

# --- Paths ---
DATA_DIR=./data
CACHE_DIR=./.cache
MLFLOW_TRACKING_URI=./mlruns

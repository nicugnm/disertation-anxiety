# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
.venv/
venv/
env/
build/
dist/

# Project data
# NOTE: data is committed to this PRIVATE repo to enable workflow on a second
# machine. If this repo ever changes to PUBLIC, restore the original exclusions
# (data/raw/* etc.) immediately — Reddit Data API Terms forbid redistribution
# of raw user text, and `docs/ethics.md` commits to ID + label release only.
# .env stays excluded regardless.
data/external/*
!data/external/.gitkeep
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Per-user full histories: real usernames + full mental-health profiles.
# Excluded even though data/raw/* is otherwise committed (see note above).
data/raw/authors/

# Cached HTTP / LLM responses — too large for git (multi-GB), also contains raw
# API payloads. Never push.
.cache/
*.cache

# Experiment tracking
# Note: experiments/runs/ IS tracked (sklearn/xgboost models are small).
# Large checkpoint files from transformers are caught by the *.safetensors /
# *.bin / *.pt rules below. mlruns/ and wandb/ are too large to track.
mlruns/
mlartifacts/
wandb/

# Models
*.pt
*.bin
*.safetensors
checkpoints/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Editors
.vscode/
.idea/
*.swp
.DS_Store
.claude/

# Local logs
*.log
install.log

# Env / secrets
.env
.env.local
secrets.yaml

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Presentation & speaker notes — kept LOCAL only, never pushed (per request).
/presentation/
/scripts/build_presentation.py
/scripts/build_speaker_notes.py
